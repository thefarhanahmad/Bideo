{
  "expo": {
    "name": "indiaTubeApp",
    "slug": "indiaTubeApp",
    "scheme": "indiatube",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/splash-icon.jpg",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.jpg",
      "bundleIdentifier": "com.farhan.indiatubeapp"
    },

    "android": {
      "package": "com.farhan.indiatubeapp",
      "icon": "./assets/icon.jpg",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "./assets/splash-icon.jpg",
        "resizeMode": "cover",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },

    "web": {
      "favicon": "./assets/fevicon.jpg"
    },

    "plugins": [
      "expo-secure-store", 
      "expo-router", 
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.jpg"
        }
      ]
    ]
  }
}
